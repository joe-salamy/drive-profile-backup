{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(python -m venv venv)",
      "Bash(venv/Scripts/python.exe -m pip install -e \".[dev]\")",
      "Bash(venv/Scripts/python.exe -m pytest tests/ -v)",
      "Bash(venv/Scripts/python.exe -m drive_backup.cli --dry-run --config config.yaml)",
      "Bash(venv/Scripts/python.exe -m pytest tests/ -q)",
      "Bash(venv/Scripts/python -m drive_backup.cli --dry-run --config config.yaml)",
      "Bash(venv/Scripts/python -c ':*)",
      "Bash(venv/Scripts/python scripts/generate_summary.py --config config.yaml --out docs)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import sys,json,subprocess; d=json.load(sys.stdin); f=d.get('tool_input',{}).get('file_path',''); r=subprocess.run(['python','-m','py_compile',f],capture_output=True,text=True) if f.endswith('.py') else None; r and r.returncode and (sys.stderr.write(r.stderr) or sys.exit(r.returncode))\"",
            "statusMessage": "Checking syntax..."
          }
        ]
      }
    ]
  }
}
